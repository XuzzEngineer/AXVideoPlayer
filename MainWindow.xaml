<Window x:Class="AXVideoPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wpf="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="AX Video Player"
        Icon="Assets/logo.png"
        Width="1200"
        Height="720"
        MinWidth="360"
        MinHeight="220"
        Background="Black"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
        MouseMove="Window_MouseMove">

    <Window.Resources>
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#202020"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#202020"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#174D86"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}" Color="#174D86"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#F2F2F2"/>

        <Style x:Key="PlayerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="MinWidth" Value="42"/>
            <Setter Property="Height" Value="34"/>
        </Style>

        <Style x:Key="LeftControlButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PlayerButtonStyle}">
            <Setter Property="Margin" Value="4,0"/>
        </Style>

        <Style x:Key="LeftControlMenuStyle" TargetType="Menu">
            <Setter Property="Background" Value="#202020"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="FadedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#66181818"/>
            <Setter Property="Foreground" Value="#E6FFFFFF"/>
            <Setter Property="BorderBrush" Value="#777777"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Opacity" Value="0.72"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SpeedComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="78"/>
            <Setter Property="Margin" Value="6,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#666666"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="1"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="2">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Grid>
                                    <ContentPresenter Margin="10,0,24,0"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"
                                                      IsHitTestVisible="False"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    <Path Width="8"
                                          Height="5"
                                          Margin="0,0,9,0"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Data="M 0 0 L 4 5 L 8 0 Z"
                                          Fill="#E0E0E0"/>
                                </Grid>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="#2A2A2A"
                                        BorderBrush="#666666"
                                        BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer CanContentScroll="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BlueSliderStyle" TargetType="Slider">
            <Setter Property="Foreground" Value="#0B3D91"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="24">
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge"
                                                  Background="#0B3D91"
                                                  BorderThickness="0"
                                                  Height="6"
                                                  VerticalAlignment="Center"/>
                                </Track.DecreaseRepeatButton>

                                <Track.Thumb>
                                    <Thumb Width="16" Height="16">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="#0B3D91"
                                                         Stroke="White"
                                                         StrokeThickness="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>

                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge"
                                                  Background="White"
                                                  BorderThickness="0"
                                                  Height="6"
                                                  VerticalAlignment="Center"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="#202020"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#202020"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#202020"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2A5B9E"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#F2F2F2"/>
            </Style.Resources>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#F4F4F4"/>
            <Setter Property="Background" Value="#202020"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <Border x:Name="ItemBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#343434"
                                    BorderThickness="0"
                                    MinWidth="142"
                                    MinHeight="{TemplateBinding MinHeight}"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="18"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter x:Name="HeaderHost"
                                                      ContentSource="Header"
                                                      RecognizesAccessKey="True"
                                                      VerticalAlignment="Center"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>

                                    <Path x:Name="SubmenuArrow"
                                          Grid.Column="1"
                                          Width="5"
                                          Height="8"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Data="M 0 0 L 5 4 L 0 8 Z"
                                          Fill="{TemplateBinding Foreground}"
                                          Visibility="Collapsed"/>
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   Placement="Right"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Fade">
                                <Border Background="#1B1B1B"
                                        BorderBrush="#3A3A3A"
                                        BorderThickness="1"
                                        Padding="4">
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom"/>
                                <Setter TargetName="ItemBorder" Property="MinWidth" Value="0"/>
                                <Setter Property="Padding" Value="10,5"/>
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#123A63"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#123A63"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#858585"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="Black">

        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="PlaylistColumn" Width="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition x:Name="TopLayoutRow" Height="46"/>
            <RowDefinition Height="*"/>
            <RowDefinition x:Name="ControlLayoutRow" Height="104"/>
        </Grid.RowDefinitions>

        <Grid x:Name="MainVideoArea"
              Grid.Row="1"
              Grid.RowSpan="1"
              Grid.Column="1"
              Background="Black"
              MouseLeftButtonDown="MainVideoArea_MouseLeftButtonDown">

            <wpf:VideoView x:Name="VideoView"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"
                           Visibility="Collapsed"
                           IsHitTestVisible="False"/>

            <Border x:Name="EmptyStatePanel"
                    Background="#2B2B2B"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">

                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <Image Source="Assets/logo.png"
                           Width="96"
                           Height="96"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,14"/>

                    <TextBlock Text="AX Video Player"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="#4A4A4A"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="Drop a video file here or click Open File"
                               FontSize="16"
                               Foreground="#777777"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border x:Name="PlaylistPanel"
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Background="#151515"
                BorderBrush="#2A2A2A"
                BorderThickness="0,0,1,0"
                Visibility="Collapsed">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="46"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="46"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Playlist"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="12,0,0,0"/>

                <ListBox x:Name="PlaylistBox"
                         Grid.Row="1"
                         Background="#101010"
                         Foreground="White"
                         BorderBrush="#2A2A2A"
                         MouseDoubleClick="PlaylistBox_MouseDoubleClick"/>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <Button Content="Add"
                            Style="{StaticResource PlayerButtonStyle}"
                            Click="AddToPlaylist_Click"/>

                    <Button Content="Clear"
                            Style="{StaticResource PlayerButtonStyle}"
                            Click="ClearPlaylist_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="TopBar"
                Grid.Row="0"
                Grid.Column="1"
                Background="#CC181818"
                BorderBrush="#2A2A2A"
                BorderThickness="0,0,0,1"
                Panel.ZIndex="10">

            <Grid>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="16,0,0,0">

                    <Image Source="Assets/logo.png"
                           Width="28"
                           Height="28"
                           Stretch="Uniform"
                           Margin="0,0,8,0"/>

                    <TextBlock Text="AX Video Player"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,12,0"/>

                    <Button Content="Open File"
                            Style="{StaticResource PlayerButtonStyle}"
                            Click="Open_Click"/>

                    <Button Content="Tools"
                            Style="{StaticResource PlayerButtonStyle}"
                            Click="Tools_Click"/>
                </StackPanel>

                <Button x:Name="HideUiButton"
                        Content="Hide UI"
                        Style="{StaticResource PlayerButtonStyle}"
                        HorizontalAlignment="Right"
                        Margin="0,6,18,6"
                        Click="HideUiButton_Click"/>
            </Grid>
        </Border>

        <Border x:Name="ControlPanel"
                Grid.Row="2"
                Grid.Column="1"
                Background="#DD181818"
                BorderBrush="#2A2A2A"
                BorderThickness="0,1,0,0"
                Padding="12"
                Panel.ZIndex="10">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="TimelineControlRow" Height="34"/>
                    <RowDefinition x:Name="TransportControlRow" Height="54"/>
                </Grid.RowDefinitions>

                <Grid x:Name="TimelineControls"
                      Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="CurrentTimeColumn" Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition x:Name="TotalTimeColumn" Width="90"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="CurrentTimeText"
                               Text="00:00"
                               HorizontalAlignment="Center"/>

                    <Slider x:Name="PositionSlider"
                            Grid.Column="1"
                            Style="{StaticResource BlueSliderStyle}"
                            Minimum="0"
                            Maximum="1000"
                            PreviewMouseLeftButtonDown="PositionSlider_PreviewMouseLeftButtonDown"
                            PreviewMouseLeftButtonUp="PositionSlider_PreviewMouseLeftButtonUp"
                            MouseMove="PositionSlider_MouseMove"
                            ValueChanged="PositionSlider_ValueChanged"/>

                    <TextBlock x:Name="TotalTimeText"
                               Grid.Column="2"
                               Text="00:00"
                               HorizontalAlignment="Center"/>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel x:Name="LeftControlGroup"
                                Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <Button x:Name="PlaylistToggleButton"
                                Content="☰ Playlist"
                                Style="{StaticResource LeftControlButtonStyle}"
                                Click="PlaylistToggleButton_Click"/>

                        <Button x:Name="PlayOrderButton"
                                Content="→"
                                Width="34"
                                MinWidth="34"
                                Height="34"
                                Padding="0"
                                Style="{StaticResource LeftControlButtonStyle}"
                                ToolTip="Play order: single"
                                Click="PlayOrderButton_Click"/>

                        <Menu x:Name="SubtitleMenu"
                              Style="{StaticResource LeftControlMenuStyle}">
                            <MenuItem Header="Subtitles">
                                <MenuItem Header="Load external subtitle..."
                                          Click="LoadSubtitle_Click"/>
                                <Separator/>

                                <MenuItem Header="Location">
                                    <MenuItem Header="Bottom" Click="SubtitleLocationBottom_Click"/>
                                    <MenuItem Header="Middle" Click="SubtitleLocationMiddle_Click"/>
                                    <MenuItem Header="Top" Click="SubtitleLocationTop_Click"/>
                                </MenuItem>

                                <MenuItem Header="Size">
                                    <MenuItem Header="Small" Click="SubtitleSizeSmall_Click"/>
                                    <MenuItem Header="Medium" Click="SubtitleSizeMedium_Click"/>
                                    <MenuItem Header="Large" Click="SubtitleSizeLarge_Click"/>
                                </MenuItem>

                                <MenuItem Header="Color">
                                    <MenuItem Header="White" Click="SubtitleColorWhite_Click"/>
                                    <MenuItem Header="Yellow" Click="SubtitleColorYellow_Click"/>
                                    <MenuItem Header="Blue" Click="SubtitleColorBlue_Click"/>
                                </MenuItem>

                                <Separator/>
                                <MenuItem Header="Disable subtitles"
                                          Click="DisableSubtitles_Click"/>
                            </MenuItem>
                        </Menu>
                    </StackPanel>

                    <StackPanel x:Name="TransportControls"
                                Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                        <Button Content="⏮" Style="{StaticResource PlayerButtonStyle}" Click="Previous_Click"/>
                        <Button x:Name="PlayPauseButton"
                                Content="▶"
                                Style="{StaticResource PlayerButtonStyle}"
                                Click="PlayPause_Click"/>

                        <Button Content="⏭" Style="{StaticResource PlayerButtonStyle}" Click="Next_Click"/>
                        <Button Content="⏹" Style="{StaticResource PlayerButtonStyle}" Click="Stop_Click"/>
                    </StackPanel>

                    <Border x:Name="VolumeControlGroup"
                            Grid.Column="2"
                            Background="#222222"
                            BorderBrush="#333333"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8,2"
                            VerticalAlignment="Center">

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right">

                            <TextBlock x:Name="VolumeLabel"
                                       Text="Vol"
                                       Margin="0,0,6,0"
                                       Cursor="Hand"
                                       MouseLeftButtonDown="VolumeLabel_MouseLeftButtonDown"/>

                            <Slider x:Name="VolumeSlider"
                                    Style="{StaticResource BlueSliderStyle}"
                                    Width="100"
                                    Minimum="0"
                                    Maximum="100"
                                    Value="100"
                                    VerticalAlignment="Center"
                                    PreviewMouseLeftButtonDown="VolumeSlider_PreviewMouseLeftButtonDown"
                                    ValueChanged="VolumeSlider_ValueChanged"/>

                            <TextBlock x:Name="VolumePercentText"
                                       Text="100%"
                                       Width="42"
                                       Margin="4,0,10,0"/>

                            <TextBlock x:Name="SpeedLabel"
                                       Text="Speed"
                                       Margin="4,0,4,0"/>

                            <ComboBox x:Name="SpeedComboBox"
                                      Style="{StaticResource SpeedComboBoxStyle}"
                                      SelectionChanged="SpeedComboBox_SelectionChanged">
                                <ComboBoxItem Content="0.5x"/>
                                <ComboBoxItem Content="0.75x"/>
                                <ComboBoxItem Content="1.0x" IsSelected="True"/>
                                <ComboBoxItem Content="1.25x"/>
                                <ComboBoxItem Content="1.5x"/>
                                <ComboBoxItem Content="2.0x"/>
                            </ComboBox>

                            <Button x:Name="CompactHideUiButton"
                                    Content="Hide UI"
                                    Style="{StaticResource PlayerButtonStyle}"
                                    Visibility="Collapsed"
                                    Click="HideUiButton_Click"/>

                            <Button Content="⛶"
                                    Style="{StaticResource PlayerButtonStyle}"
                                    Click="Fullscreen_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="AudioEqualizerPanel"
                Grid.Row="1"
                Grid.RowSpan="2"
                Grid.Column="1"
                Width="560"
                MaxHeight="520"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,14,18,0"
                Background="#F0202020"
                BorderBrush="#4A4A4A"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16"
                Panel.ZIndex="40"
                Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Audio Equalizer"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Left"/>
                        <Button Content="×"
                                Width="32"
                                Height="28"
                                HorizontalAlignment="Right"
                                Style="{StaticResource PlayerButtonStyle}"
                                Click="CloseAudioEqualizerPanel_Click"/>
                    </Grid>

                    <CheckBox x:Name="AudioEqualizerEnableCheckBox"
                              Content="Enable audio equalizer"
                              Foreground="White"
                              Margin="0,0,0,10"
                              Checked="AudioEqualizerEnable_Checked"
                              Unchecked="AudioEqualizerEnable_Checked"/>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Preamp"/>
                        <Slider x:Name="AudioPreampSlider"
                                Grid.Column="1"
                                Minimum="-20"
                                Maximum="20"
                                Value="0"
                                Tag="preamp"
                                Style="{StaticResource BlueSliderStyle}"
                                ValueChanged="AudioEqualizerSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" Text="dB"/>
                    </Grid>

                    <UniformGrid Columns="2" Margin="0,8,0,0">
                        <StackPanel Margin="0,3">
                            <TextBlock Text="60 Hz"/>
                            <Slider x:Name="AudioBand0Slider" Minimum="-20" Maximum="20" Value="0" Tag="band0" Style="{StaticResource BlueSliderStyle}" ValueChanged="AudioEqualizerSlider_ValueChanged"/>
                        </StackPanel>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="170 Hz"/>
                            <Slider x:Name="AudioBand1Slider" Minimum="-20" Maximum="20" Value="0" Tag="band1" Style="{StaticResource BlueSliderStyle}" ValueChanged="AudioEqualizerSlider_ValueChanged"/>
                        </StackPanel>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="310 Hz"/>
                            <Slider x:Name="AudioBand2Slider" Minimum="-20" Maximum="20" Value="0" Tag="band2" Style="{StaticResource BlueSliderStyle}" ValueChanged="AudioEqualizerSlider_ValueChanged"/>
                        </StackPanel>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="600 Hz"/>
                            <Slider x:Name="AudioBand3Slider" Minimum="-20" Maximum="20" Value="0" Tag="band3" Style="{StaticResource BlueSliderStyle}" ValueChanged="AudioEqualizerSlider_ValueChanged"/>
                        </StackPanel>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="1 kHz"/>
                            <Slider x:Name="AudioBand4Slider" Minimum="-20" Maximum="20" Value="0" Tag="band4" Style="{StaticResource BlueSliderStyle}" ValueChanged="AudioEqualizerSlider_ValueChanged"/>
                        </StackPanel>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="3 kHz"/>
                            <Slider x:Name="AudioBand5Slider" Minimum="-20" Maximum="20" Value="0" Tag="band5" Style="{StaticResource BlueSliderStyle}" ValueChanged="AudioEqualizerSlider_ValueChanged"/>
                        </StackPanel>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="6 kHz"/>
                            <Slider x:Name="AudioBand6Slider" Minimum="-20" Maximum="20" Value="0" Tag="band6" Style="{StaticResource BlueSliderStyle}" ValueChanged="AudioEqualizerSlider_ValueChanged"/>
                        </StackPanel>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="12 kHz"/>
                            <Slider x:Name="AudioBand7Slider" Minimum="-20" Maximum="20" Value="0" Tag="band7" Style="{StaticResource BlueSliderStyle}" ValueChanged="AudioEqualizerSlider_ValueChanged"/>
                        </StackPanel>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="14 kHz"/>
                            <Slider x:Name="AudioBand8Slider" Minimum="-20" Maximum="20" Value="0" Tag="band8" Style="{StaticResource BlueSliderStyle}" ValueChanged="AudioEqualizerSlider_ValueChanged"/>
                        </StackPanel>
                        <StackPanel Margin="0,3">
                            <TextBlock Text="16 kHz"/>
                            <Slider x:Name="AudioBand9Slider" Minimum="-20" Maximum="20" Value="0" Tag="band9" Style="{StaticResource BlueSliderStyle}" ValueChanged="AudioEqualizerSlider_ValueChanged"/>
                        </StackPanel>
                    </UniformGrid>

                    <Button Content="Reset audio equalizer"
                            HorizontalAlignment="Left"
                            Margin="0,12,0,0"
                            Style="{StaticResource PlayerButtonStyle}"
                            Click="AudioEqualizerReset_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border x:Name="VideoEqualizerPanel"
                Grid.Row="1"
                Grid.RowSpan="2"
                Grid.Column="1"
                Width="520"
                MaxHeight="500"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,14,18,0"
                Background="#F0202020"
                BorderBrush="#4A4A4A"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16"
                Panel.ZIndex="41"
                Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Video Equalizer"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Left"/>
                        <Button Content="×"
                                Width="32"
                                Height="28"
                                HorizontalAlignment="Right"
                                Style="{StaticResource PlayerButtonStyle}"
                                Click="CloseVideoEqualizerPanel_Click"/>
                    </Grid>

                    <CheckBox x:Name="VideoEqualizerEnableCheckBox"
                              Content="Enable video equalizer"
                              Foreground="White"
                              Margin="0,0,0,10"
                              Checked="VideoEqualizerEnable_Checked"
                              Unchecked="VideoEqualizerEnable_Checked"/>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Brightness"/>
                        <Slider x:Name="BrightnessSlider" Grid.Column="1" Minimum="0" Maximum="2" Value="1" Tag="brightness" Style="{StaticResource BlueSliderStyle}" ValueChanged="VideoEqualizerSlider_ValueChanged"/>
                    </Grid>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Contrast"/>
                        <Slider x:Name="ContrastSlider" Grid.Column="1" Minimum="0" Maximum="2" Value="1" Tag="contrast" Style="{StaticResource BlueSliderStyle}" ValueChanged="VideoEqualizerSlider_ValueChanged"/>
                    </Grid>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Saturation"/>
                        <Slider x:Name="SaturationSlider" Grid.Column="1" Minimum="0" Maximum="3" Value="1" Tag="saturation" Style="{StaticResource BlueSliderStyle}" ValueChanged="VideoEqualizerSlider_ValueChanged"/>
                    </Grid>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Gamma"/>
                        <Slider x:Name="GammaSlider" Grid.Column="1" Minimum="0.1" Maximum="3" Value="1" Tag="gamma" Style="{StaticResource BlueSliderStyle}" ValueChanged="VideoEqualizerSlider_ValueChanged"/>
                    </Grid>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Hue"/>
                        <Slider x:Name="HueSlider" Grid.Column="1" Minimum="-180" Maximum="180" Value="0" Tag="hue" Style="{StaticResource BlueSliderStyle}" ValueChanged="VideoEqualizerSlider_ValueChanged"/>
                    </Grid>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Sharpness"/>
                        <Slider x:Name="SharpnessSlider" Grid.Column="1" Minimum="0" Maximum="2" Value="0" Tag="sharpness" Style="{StaticResource BlueSliderStyle}" ValueChanged="VideoEqualizerSlider_ValueChanged"/>
                    </Grid>

                    <TextBlock Text="Note: brightness, contrast, saturation, hue, and gamma use VLC video adjustment. Sharpness is exposed as a modular control; applying it depends on VLC sharpen-filter support."
                               TextWrapping="Wrap"
                               Foreground="#CFCFCF"
                               Margin="0,8,0,4"/>

                    <Button Content="Reset video equalizer"
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0"
                            Style="{StaticResource PlayerButtonStyle}"
                            Click="VideoEqualizerReset_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border x:Name="ResumePromptPanel"
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="1"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="18"
                Background="#E01F1F1F"
                BorderBrush="#555555"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14,10"
                Panel.ZIndex="60"
                Opacity="0"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="ResumePromptText"
                           Text="Resume from 00:00?"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Yes"
                            Width="72"
                            Height="28"
                            Margin="0,0,8,0"
                            Click="ResumePromptYes_Click"/>
                    <Button Content="No"
                            Width="72"
                            Height="28"
                            Click="ResumePromptNo_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Popup x:Name="FullscreenTopPopup"
               PlacementTarget="{Binding ElementName=RootGrid}"
               Placement="Relative"
               HorizontalOffset="0"
               VerticalOffset="0"
               AllowsTransparency="True"
               StaysOpen="True"
               Focusable="False"
               IsOpen="False">
            <Grid x:Name="FullscreenTopHost"
                  Background="#01000000"
                  ClipToBounds="False"
                  IsHitTestVisible="True"/>
        </Popup>

        <Popup x:Name="FullscreenBottomPopup"
               PlacementTarget="{Binding ElementName=RootGrid}"
               Placement="Relative"
               HorizontalOffset="0"
               VerticalOffset="0"
               AllowsTransparency="True"
               StaysOpen="True"
               Focusable="False"
               IsOpen="False">
            <Grid x:Name="FullscreenBottomHost"
                  Background="#01000000"
                  ClipToBounds="False"
                  IsHitTestVisible="True"/>
        </Popup>

        <Popup x:Name="FullscreenPlaylistPopup"
               PlacementTarget="{Binding ElementName=RootGrid}"
               Placement="Relative"
               HorizontalOffset="0"
               VerticalOffset="46"
               AllowsTransparency="True"
               StaysOpen="True"
               Focusable="False"
               IsOpen="False">
            <Grid x:Name="FullscreenPlaylistHost"
                  Width="320"
                  Background="#01000000"
                  ClipToBounds="True"
                  IsHitTestVisible="True"/>
        </Popup>

        <Popup x:Name="ShowUiPopup"
               PlacementTarget="{Binding ElementName=RootGrid}"
               Placement="Relative"
               AllowsTransparency="True"
               StaysOpen="True"
               IsOpen="False">
            <Button x:Name="ShowUiButton"
                    Content="Show UI"
                    Style="{StaticResource FadedButtonStyle}"
                    ToolTip="Show UI"
                    Visibility="Collapsed"
                    Click="ShowUiButton_Click"
                    MouseEnter="ShowUiButton_MouseEnter"/>
        </Popup>
    </Grid>
</Window>
